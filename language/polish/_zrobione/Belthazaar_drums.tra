@0 = ~[Quasit] Witajcie, wielkoludy!~
@1 = ~[player] Myślałem, że przyzywam glabrezu, a nie jakiegoś quasita.~ ~[player] Myślałam, że przyzywam glabrezu, a nie jakiegoś quasita.~
@2 = ~[player] Przywołaj glabrezu Belthazaara.~
@3 = ~[Quasit] Cierpliwości, cierpliwości! Belthazaar, wielki glabrezu, nadchodzi. Zostałem wysłany przodem tylko po to, by sprawdzić, czy teren jest czysty!~
@4 = ~[player] Zatem przywołaj go.~
@5 = ~[Quasit] Hmm... dajcie mi się rozejrzeć...~
@6 = ~[Quasit] Czas jeszcze nie nadszedł! Nie bądźcie tacy niecierpliwi!~
@7 = ~[Quasit] Wygląda na to, że wszystko w porządku! Mój mistrz pojawi się tu lada chwila, przygotujcie się!~
@8 = ~[player] Przestań gadać i walcz!~
@9 = ~[Quasit] Wy głupcy! Mojego mistrza nie da się przywołać tutaj, w Otchłani! Można to zrobić tylko na planie materialnym!~