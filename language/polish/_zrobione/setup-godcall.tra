@1180 = ~Twoja dusza zasili mą potęgę.~ [AC#WNIH1] // Nighthag soundset
@1181 = ~Śnij o mnie słodko, śmiertelniku!~ [AC#WNIH2]  // Nighthag soundset
@1182 = ~Jestem potęgą, rozkoszą i zatraceniem.~ [AC#WMAR1] // Maretta soundset
@1183 = ~Witaj w krainie rozpaczy, gdzie nie zaznasz ukojenia, śmiertelniku. Jam jest Maretta, pani Samory.~ [AC#WMAR2] // Maretta soundset
@1184 = ~Podziwiaj me piękno albo precz z moich oczu.~ [AC#WMAR3] // Maretta soundset
@1186 = ~Witajcie, śmiertelnicy.~ [AC#WMEF1] // Mefisto initial meeting
@1187 = ~Witajcie, śmiertelnicy.~ [AC#WMEF1] //[AC#WMEF2] Mefisto#2, need to change later
@1188 = ~Och, to znowu wy.~ [AC#WMEF3] // Mefisto
@1190 = ~Pieniądz mówi. Bogactwo śpiewa.~ [AC#WTHA2] // Tharundar Olehm
@1191 = ~Dobry interes.~ [AC#WTHA5] // Tharundar Olehm
@1195 = ~Pozdrowienia. Nazywam się Kyriani Agrivar. Jestem kapłanką Selûne z Waterdeep.~ [AC#WKYR1]

@1210 = ~Stój spokojnie, śmiertelniku!~ [AC#WBAB2]
@1211 = ~Armia maszeruje po trupach swoich śmiertelników!~ [AC#WBAB1]
@1212 = ~Mam bardzo, bardzo zły humor.~ [AC#WDEM1]
@1213 = ~Mam najlepsze ceny na południe od tej piekielnej dziury.~ [AC#WMER1]
@1214 = ~W mojej tawernie jest brudniej niż w dupie diabła.~ [AC#WSOL1]
@1215 = ~Lękaj się mnie, bo sprowadzę na ciebie obłęd.~ [AC#WDEM2]
@1216 = ~W tej grze dusz prawo zawsze zwycięża.~ [AC#WAPH1]
@1217 = ~Mam mnóstwo podłych towarów!~ [AC#WMER2]
@1218 = ~Jestem ucieleśnieniem chwały!~ [AC#W75S1]
@1219 = ~Pokaż, na co cię stać!~ [AC#W74W3]
@1220 = ~Wystąp i uwolnij swój gniew.~ [AC#W74W4]
@1221 = ~Ujawnij swą wściekłość i pokaż swą moc.~ [AC#W74W5]
@1222 = ~Lepszy bąk biesa niż bełt w plecach.~ [AC#WDWR1]
@1223 = ~Tyle sfer, tyle nauki.~ [AC#WDWR2]
@1224 = ~Dla chwały Baator!~ [AC#WAPH2]
@1225 = ~Magia tutaj to nie jest zwykła sztuczka kuglarska.~ [AC#WMSV1]
@1226 = ~Nie rzucaj czarów tak, jak rzucasz karty.~ [AC#WMSV2]
@1227 = ~Z drogi, wielkoludy!~ [AC#WSQRL]

@1230 = ~Jestem boginią bogactwa. O tak!~ [AC#WWAE0]
@1240 = ~Po co używać własnej mocy, skoro można zmusić innych do marnowania ich własnej?~ [AC#WVER0]


@1250 = ~Kto wchodzi w mą sieć?~ [AC#WBEB0]
@1251 = ~Poczuj mój jadowity uścisk!~ [AC#WBEB2]

@1255 = ~Patrz pod nogi.~ [AC#WLIL1]
@1256 = ~Blask księżyca prowadzi mnie przez mrok.~ [AC#WLIL2]

@1260 = ~Ahhh... tak ciemno...~ [AC#WHALA]

@1270 = ~Pozdrawiamy cię, istotko z mięsa.~ [AC#WMONA]
@1271 = ~Jedno oko, jeden kierunek.~ [AC#WMON0]
@1272 = ~Wykryto wrogi obiekt o pojedynczym ukierunkowaniu...~ [AC#WMONB]
@1273 = ~Nie ma lepszych jednostek od nas.~ [AC#WMONC]
@1274 = ~Myślimy jako jedność.~ [AC#WMOND]
@1275 = ~Pojedynczy atak przeciwko nam wszystkim.~ [AC#WMONE]
@1276 = ~Opuszczanie wspólnoty umysłowej...~ [AC#WMONF]

@1280 = ~Ja zły.~ [AC#WBAP1]
@1281 = ~Ja silny. Ty słaby!~ [AC#WBAP2]

@1285 = ~Przeznaczenie czy nie, nie zagoszczę tu długo.~ [AC#WNYS1]
@1286 = ~Muszę być wolna.~ [AC#WNYS2]

@1290 = ~~ [AM1900B1]

@1300 = ~Niech bogactwo i pomyślność towarzyszą każdemu twojemu krokowi.~ [AC#WWAUX]

